<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp"/>
            <gradient
                android:startColor="#FFD700"
                android:centerColor="#FFA500"
                android:endColor="#FFD700"
                android:angle="0"
                android:type="linear"/>
        </shape>
    </item>
    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <gradient
                android:startColor="#1A0A3C"
                android:centerColor="#2D1B6B"
                android:endColor="#1A0A3C"
                android:angle="0"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>