<?xml version="1.0" encoding="utf-8"?>
<!-- Lưu tại: res/drawable/btn_hex_normal.xml -->
<!-- Nút bình thường: viền xanh dương, nền tối -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Lớp viền ngoài xanh sáng -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00BFFF"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <!-- Lớp nền trong tối xanh -->
    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0A1E4A"
                android:centerColor="#0D2855"
                android:endColor="#0A1E4A"
                android:angle="0"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>

</layer-list>