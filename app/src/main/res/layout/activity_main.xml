<?xml version="1.0" encoding="utf-8"?>
<!-- Lưu tại: res/layout/activity_main.xml — thay toàn bộ nội dung cũ -->
<!--
    LinearLayout: xếp các View theo chiều dọc (vertical) hoặc ngang (horizontal)
    - orientation="vertical" → xếp từ trên xuống dưới
    - gravity="center" → căn giữa tất cả con
    - layout_weight → chia tỉ lệ không gian
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#0A0520"
    android:padding="24dp">

    <!-- Đẩy logo xuống giữa màn hình một chút -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Logo ── -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter"/>

    <!-- Fallback nếu chưa có ảnh logo -->
    <!--
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💰 AI LÀ TRIỆU PHÚ"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD700"/>
    -->

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Nút BẮT ĐẦU ── -->
    <Button
        android:id="@+id/btn_play"
        android:layout_width="260dp"
        android:layout_height="54dp"
        android:text="◆  BẮT ĐẦU  ◆"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:letterSpacing="0.08"
        android:background="@drawable/btn_millionaire"
        android:stateListAnimator="@null"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="14dp"/>

    <!-- ── Nút HƯỚNG DẪN ── -->
    <Button
        android:id="@+id/btn_instructions"
        android:layout_width="260dp"
        android:layout_height="54dp"
        android:text="◆  HƯỚNG DẪN  ◆"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:letterSpacing="0.08"
        android:background="@drawable/btn_millionaire"
        android:stateListAnimator="@null"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="14dp"/>

    <!-- ── Nút THOÁT ── -->
    <Button
        android:id="@+id/btn_exit"
        android:layout_width="260dp"
        android:layout_height="54dp"
        android:text="◆  THOÁT  ◆"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FF6B6B"
        android:letterSpacing="0.08"
        android:background="@drawable/btn_millionaire"
        android:stateListAnimator="@null"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Version ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0 — Android Edition"
        android:textSize="11sp"
        android:textColor="#444466"
        android:layout_marginBottom="8dp"/>

</LinearLayout>