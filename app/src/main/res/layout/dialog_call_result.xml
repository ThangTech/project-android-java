<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#2D1B6B"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <ImageView
        android:id="@+id/iv_expert_avatar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:background="@drawable/avatar_cu_trong_xoay"
        android:clipToOutline="true"
        android:src="@drawable/cu_trong_xoay" />

    <TextView
        android:id="@+id/tv_expert_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cù Trọng Xoay"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_expert_answer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Theo tôi đáp án đúng là C"
        android:textColor="#FFD700"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_close_call"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_millionaire"
        android:text="Đóng"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"/>
</LinearLayout>