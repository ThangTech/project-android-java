<?xml version="1.0" encoding="utf-8"?>
<!-- Lưu tại: res/layout/activity_game.xml -->
<!--
    Màn hình game gồm (từ trên xuống):
    1. Header: số câu + tiền hiện tại
    2. Câu hỏi
    3. 4 nút đáp án
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0520"
    android:padding="16dp">

    <!-- ── Header: số câu + tiền ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_question_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Câu 1 / 15"
            android:textColor="#AAAACC"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_current_money"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200.000 đ"
            android:textColor="#FFD700"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Đường kẻ ngang -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A5A"
        android:layout_marginBottom="16dp"/>

    <!-- ── Khoảng trống đẩy câu hỏi xuống giữa ── -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Câu hỏi ── -->
    <TextView
        android:id="@+id/tv_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nội dung câu hỏi sẽ hiện ở đây?"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:padding="16dp"
        android:background="@drawable/bg_question"
        android:layout_marginBottom="8dp"/>

    <!-- ── Khoảng trống ── -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── 4 Nút đáp án ── -->

    <!-- Hàng A + B -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btn_answer_a"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="A. Đáp án"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/btn_hex_normal"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_answer_b"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="B. Đáp án"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/btn_hex_normal"
            android:stateListAnimator="@null"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <!-- Hàng C + D -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btn_answer_c"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="C. Đáp án"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/btn_hex_normal"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_answer_d"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="D. Đáp án"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/btn_hex_normal"
            android:stateListAnimator="@null"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

</LinearLayout>