<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#2D1B6B"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/tg_sage"
        android:scaleType="fitCenter"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NHÀ THÔNG THÁI"
        android:textColor="#FFD700"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_sage_evidence"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dẫn chứng sẽ hiển thị ở đây..."
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_sage_advice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hãy cân nhắc kỹ!"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_close_sage"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_millionaire"
        android:text="Đóng"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"/>
</LinearLayout>
