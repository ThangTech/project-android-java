<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUẢN LÝ CÂU HỎI"
        android:textSize="24sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_question_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tổng câu hỏi: 0"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="5dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="5dp">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Tìm kiếm câu hỏi..."
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="@drawable/btn_rect_purple"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1" />

        <Spinner
            android:id="@+id/sp_filter_level"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_rect_purple"
            android:paddingHorizontal="8dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_clear_filter"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:text="Xóa bộ lọc"
        android:textSize="12sp"
        android:background="@drawable/btn_rect_purple"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="5dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/lv_questions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#333333"
        android:dividerHeight="1dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp" />

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chưa có câu hỏi nào!"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:visibility="gone"
        android:layout_gravity="center" />

    <Button
        android:id="@+id/btn_add_question"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="THÊM CÂU HỎI MỚI"
        android:textSize="14sp"
        android:background="@drawable/btn_rect_purple"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_back"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="QUAY LẠI"
        android:textSize="16sp"
        android:background="@drawable/btn_rect_purple"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp" />

</LinearLayout>